# Shared secret Zap 1 must send in the X-Webhook-Secret header
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Embedding model, runs locally via sentence-transformers
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Lead scoring thresholds (0-100 composite score)
HOT_THRESHOLD=80
WARM_THRESHOLD=50

# Groq free-tier API for one-line lead summaries (optional — leave blank to skip)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google Sheets — service account JSON downloaded from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_SHEET_ID=

# Outbound Zapier "Catch Hook" URLs for Zap 2's two paths
ZAPIER_HOT_WEBHOOK_URL=
ZAPIER_DEFAULT_WEBHOOK_URL=

# Google Sheets — service account credentials
# Local dev: point this at your downloaded JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# Render (or any host without secret file uploads): paste the ENTIRE JSON
# key file's contents here instead, as a single line. Leave blank locally —
# when set, this takes priority over GOOGLE_SERVICE_ACCOUNT_FILE.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
